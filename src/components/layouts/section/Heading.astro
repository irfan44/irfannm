---
interface Props {
  title: string;
  description?: string;
  additionalClass?: string;
}

const { title, description = "", additionalClass = "" } = Astro.props;
---

<div class={additionalClass}>
  <div>
    <h1 class="mb-6">{title}</h1>
    {description && <p>{description}</p>}
  </div>
  <slot />
</div>
