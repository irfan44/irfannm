---
import { Icon } from "@twodft/astro-icon/components";
import { Picture } from "astro:assets";

import ExternalLink from "@components/ui/links/ExternalLink.astro";
import { convertDate } from "@libs/utils";

import type { Project } from "@libs/business/entity";

interface Props {
  project: Project;
}

const { project } = Astro.props;

const PLACEHOLDER_IMAGE_URL =
  "https://res.cloudinary.com/dflb9qqcu/image/upload/v1714286335/irfannm/projects/qfle9tpzyggdn1y9s90n.png";

const startingDate = convertDate(project.startingDate);
const endDate = project.endDate ? convertDate(project.endDate) : "Present";
const hasProjectLinks = Boolean(project.url || project.sourceCode);
---

<h1 class="mb-4 text-left md:text-5xl md:leading-none">{project.name}</h1>
{project.company && <p>{project.company}</p>}
<p class="mb-4">{startingDate} - {endDate}</p>
{
  hasProjectLinks && (
    <div class="mb-8">
      <div class="flex space-x-6">
        {project.url && (
          <ExternalLink title="Visit website" href={project.url} withIcon>
            <span>Visit</span>
          </ExternalLink>
        )}
        {project.sourceCode && (
          <ExternalLink
            title="View source code"
            href={project.sourceCode}
            withIcon={false}
          >
            <Icon
              name="github"
              class="text-project-source dark:text-project-source-dark text-xl"
            />
            <span>Source code</span>
          </ExternalLink>
        )}
      </div>
    </div>
  )
}
<Picture
  class="mb-8 rounded-2xl object-cover"
  src={project.image ?? PLACEHOLDER_IMAGE_URL}
  alt={`Cover for ${project.name}`}
  height="390"
  width="711"
  loading="eager"
/>
