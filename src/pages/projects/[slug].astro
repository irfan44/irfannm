---
import { Icon } from "@twodft/astro-icon/components";
import { Picture } from "astro:assets";

import Chip from "@components/ui/chips/Chip.astro";
import ExternalLink from "@components/ui/links/ExternalLink.astro";
import DetailLayout from "@layouts/DetailLayout.astro";
import { ProjectHandler } from "@libs/handlers/project";
import { convertDate } from "@libs/utils";

import type { BreadcrumbItems } from "@components/ui/breadcrumbs/breadcrumb.types";

export async function getStaticPaths() {
  const projects = await ProjectHandler.getProjects();
  if (!projects) throw Astro.redirect("/500");

  return projects.map((project) => ({
    params: { slug: project.slug },
  }));
}

const { slug } = Astro.params;

const project = await ProjectHandler.getProject(slug);
if (!project) throw Astro.redirect("/404");

const breadcrumbItems: BreadcrumbItems = [
  { title: "Home", path: "/" },
  { title: "Projects", path: "/projects" },
];

const startingDate = convertDate(project.startingDate);
const endDate = project.endDate ? convertDate(project.endDate) : "Present";
const hasProjectLinks = Boolean(project.url || project.sourceCode);

const placeholderImageUrl =
  "https://res.cloudinary.com/dflb9qqcu/image/upload/v1714286335/irfannm/projects/qfle9tpzyggdn1y9s90n.png";
---

<DetailLayout
  title={`${project.name} | Projects`}
  excerpt={project.excerpt}
  breadcrumbItems={breadcrumbItems}
>
  <h1 class="mb-4 text-left md:text-5xl md:leading-none">{project.name}</h1>
  {project.company && <div>{project.company}</div>}
  <div class="mb-4">{startingDate} - {endDate}</div>
  {
    hasProjectLinks && (
      <div class="mb-8">
        <div class="flex space-x-6">
          {project.url && (
            <ExternalLink title="Visit website" href={project.url} withIcon>
              <span>Visit</span>
            </ExternalLink>
          )}
          {project.sourceCode && (
            <ExternalLink
              title="View source code"
              href={project.sourceCode}
              withIcon={false}
            >
              <Icon name="github" class="text-xl text-black dark:text-white" />
              <span>Source code</span>
            </ExternalLink>
          )}
        </div>
      </div>
    )
  }
  <Picture
    class="mb-8 rounded-2xl object-cover"
    src={project.image ? project.image : placeholderImageUrl}
    alt={`Cover for ${project.name}`}
    height="390"
    width="711"
    loading="eager"
  />
  <div class="space-y-6">
    {
      project.overview && (
        <div>
          <h2 class="mb-4">Overview</h2>
          <p class="wrap-break-word">{project.overview}</p>
        </div>
      )
    }
    {
      project.role && (
        <div>
          <h2 class="mb-4">Role</h2>
          <p>{project.role}</p>
        </div>
      )
    }
    {
      project.responsibilities && project.responsibilities.length > 0 && (
        <div>
          <h2 class="mb-4">What I do</h2>
          <ul class="ml-5 list-disc">
            {project.responsibilities.map((value) => {
              return <li class="wrap-break-word">{value}</li>;
            })}
          </ul>
        </div>
      )
    }
    <div>
      <h2 class="mb-4">Tech Stack</h2>
      <div class="flex flex-wrap gap-2">
        {
          project.techStack.map((stack) => {
            return <Chip additionalClass="dark:!bg-neutral-800">{stack}</Chip>;
          })
        }
      </div>
    </div>
  </div>
</DetailLayout>
