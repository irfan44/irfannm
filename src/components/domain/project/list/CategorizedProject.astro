---
import TabPanel from "@components/ui/tabs/TabPanel.astro";
import Tabs from "@components/ui/tabs/Tabs.astro";

import ProjectList from "./base/ProjectList.astro";

import type { Projects } from "@libs/business/entity";

interface Props {
  workProjects: Projects;
  personalProjects: Projects;
}

const { workProjects, personalProjects } = Astro.props;

const tabs = [
  { id: "personal", label: "Personal 👨‍💻" },
  { id: "work", label: "Work 💼" },
];
---

<Tabs tabs={tabs} additionalClass="flex justify-center mb-8">
  <TabPanel id="personal" active>
    <ProjectList projects={personalProjects} />
  </TabPanel>
  <TabPanel id="work"><ProjectList projects={workProjects} /></TabPanel>
</Tabs>
