---
import CategorizedPost from "@components/domain/blog/list/CategorizedPost.astro";
import HeroPost from "@components/domain/blog/list/HeroPost.astro";
import Heading from "@components/layouts/section/Heading.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { PostHandler } from "@libs/handlers";

const categorizedPosts = await PostHandler.getCategorizedPosts();

const heroPost = categorizedPosts ? categorizedPosts[0].posts[0] : null;
---

<BaseLayout title="Blog" description="Irfan Nurghiffari Muhajir's blog posts">
  <Heading
    title="Blog"
    description="Place where you can read my writing. I mainly write about tech, finance, and investment stuff."
    additionalClass="space-y-12"
  >
    {heroPost && <HeroPost post={heroPost} />}
    {
      categorizedPosts && (
        <CategorizedPost categorizedPosts={categorizedPosts} />
      )
    }
  </Heading>
</BaseLayout>
