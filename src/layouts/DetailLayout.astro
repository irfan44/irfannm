---
import Breadcrumb from "@components/ui/breadcrumbs/Breadcrumb.astro";

import BaseLayout from "./BaseLayout.astro";

import type { BreadcrumbItems } from "@components/ui/breadcrumbs/breadcrumb.types";

interface Props {
  title: string;
  excerpt: string;
  ogImage?: string;
  breadcrumbItems: BreadcrumbItems;
  additionalClass?: string;
}

const { title, excerpt, ogImage, breadcrumbItems, additionalClass } =
  Astro.props;
---

<BaseLayout
  title={title}
  description={excerpt}
  ogImage={ogImage}
  currentPath={Astro.url.pathname}
  additionalClass={additionalClass}
>
  <section class="mx-auto mb-24 max-w-3xl">
    <Breadcrumb items={breadcrumbItems} additionalClass="mb-2" />
    <slot />
  </section>
  <section class="mb-32"><slot name="otherDetail" /></section>
</BaseLayout>
