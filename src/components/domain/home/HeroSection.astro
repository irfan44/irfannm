---
import { Image } from "astro:assets";

import OpenSocials from "@components/shared/cta/OpenSocials.astro";
import ResumeButton from "@components/shared/cta/ResumeButton.astro";

interface Props {
  description: string;
  resumeUrl: string;
}

const { description, resumeUrl } = Astro.props;
---

<div class="mb-12 flex flex-col items-center py-6 md:flex-row">
  <div class="space-y-6 md:w-1/2">
    <div>
      <h1>Hi,</h1>
      <h1>
        I&apos;m
        <span
          class="bg-secondary rounded-lg border border-neutral-200 px-2 dark:border-neutral-700 dark:bg-neutral-800"
        >
          Irfan!
        </span> 👋
      </h1>
    </div>
    <p>{description}</p>
    <ResumeButton resumeUrl={resumeUrl} />
    <div class="pt-8"><OpenSocials type="icon" /></div>
  </div>
  <div class="flex justify-center md:w-1/2">
    <Image
      class="h-100"
      src="https://res.cloudinary.com/dflb9qqcu/image/upload/f_auto,q_auto/v1/irfannm/person"
      alt="Hero"
      height="400"
      width="320"
      loading="eager"
    />
  </div>
</div>
