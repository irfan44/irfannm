---
import { NAV_MENUS } from "@libs/constants";

const currentPath = Astro.url.pathname;
---

{
  NAV_MENUS.map(({ name, link }) => {
    const isActive =
      currentPath === link || (currentPath.startsWith(link) && link !== "/");
    return (
      <li>
        <a
          class={`hover:text-nav-link-hover dark:hover:text-nav-link-hover-dark ${isActive ? "font-bold" : ""}`}
          href={link}
        >
          {name}
        </a>
      </li>
    );
  })
}
