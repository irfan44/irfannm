---
import { Icon } from "@twodft/astro-icon/components";

import NavMenuList from "@components/layouts/navMenu/NavMenuList.astro";
import ContactButton from "@components/shared/cta/ContactButton.astro";
import OpenSocials from "@components/shared/cta/OpenSocials.astro";
import Logo from "@components/shared/Logo.astro";
---

<footer class="container mx-auto px-5 md:px-16 lg:px-32">
  <div
    class="bg-footer-bg border-footer-border dark:border-footer-border-dark dark:bg-footer-bg-dark mt-32 mb-8 flex rounded-2xl border p-12"
  >
    <div class="mx-auto flex-1 text-center md:mx-0 md:text-left">
      <ul class="flex list-none flex-col space-y-1 md:hidden">
        <NavMenuList />
      </ul>
      <div class="mt-4 mb-4 md:mt-0 md:pr-8"><Logo /></div>
      <div class="mb-8 flex justify-center space-x-4 md:justify-start">
        <OpenSocials type="icon" />
      </div>
      <div class="mb-4 flex justify-center md:justify-start">
        <ContactButton />
      </div>
      <div>
        <p class="text-sm">
          © 2022 - {new Date().getFullYear()} Irfan Nurghiffari Muhajir
        </p>
        <p class="text-sm">With 😻 using Astro & Tailwind CSS</p>
      </div>
      <div class="mt-6 flex justify-center md:hidden">
        <a
          href="https://github.com/irfan44/irfannm"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center text-sm"
          title="Source code"
        >
          <Icon
            name="github"
            class="text-footer-icon dark:text-footer-icon-dark mr-2 text-xl"
          />
          Source code
        </a>
      </div>
    </div>
    <div class="hidden flex-col justify-between md:flex">
      <ul class="flex w-fit flex-col">
        <NavMenuList />
      </ul>
      <a
        href="https://github.com/irfan44/irfannm"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center text-sm"
        title="Source code"
      >
        <Icon
          name="github"
          class="text-footer-icon dark:text-footer-icon-dark mr-2 text-xl"
        />
        Source code
      </a>
    </div>
  </div>
</footer>
