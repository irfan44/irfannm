---
interface Props {
  additionalClass?: string;
}

const { additionalClass = "" } = Astro.props;
---

<div
  class:list={[
    "bg-chip-bg dark:bg-chip-bg-dark dark:border-chip-border-dark text-chip-text border-chip-bg dark:text-chip-text-dark flex items-center rounded-lg border px-2 py-1 text-sm",
    additionalClass,
  ]}
>
  <slot />
</div>
