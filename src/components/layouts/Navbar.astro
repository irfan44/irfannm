---
import { Icon } from "@twodft/astro-icon/components";

import ContactButton from "@components/cta/ContactButton.astro";
import NavMenuList from "@components/layouts/NavMenuList.astro";
import NavMenuTab from "@components/layouts/NavMenuTab.astro";
import Logo from "@components/shared/Logo.astro";

import ThemeSwitcher from "./ThemeSwitcher.astro";
---

<nav
  class="z-50 container mx-auto mt-4 w-full bg-neutral-50 px-5 md:px-16 lg:px-32 dark:bg-neutral-900"
>
  <div class="flex items-center justify-between py-4">
    <div><Logo /></div>
    <div class="flex items-center space-x-4 md:hidden">
      <ThemeSwitcher />
      <button
        id="nav-menu-mobile-button"
        class="relative z-50 ml-2 flex items-center"
        type="button"
        title="Menu"
      >
        <Icon
          name="close"
          id="nav-button-close"
          class="text-xl"
          style="display: none;"
        />
        <Icon
          name="menu"
          id="nav-button-menu"
          class="text-xl"
          style="display: block;"
        />
      </button>
    </div>
    <div class="hidden h-9.5 md:block"><NavMenuTab /></div>
    <div class="hidden md:block"><ThemeSwitcher /></div>
  </div>
  <div
    id="nav-overlay"
    class="invisible fixed inset-0 bg-black/80 opacity-0 transition-opacity duration-300 md:hidden dark:bg-black/85"
    style="z-index: 40;"
  >
  </div>
  <div
    id="nav-menu-mobile"
    class="invisible absolute right-0 left-0 -translate-y-2 px-5 opacity-0 transition-all duration-300 md:hidden"
    style="z-index: 45;"
  >
    <div class="mx-auto max-w-7xl">
      <div
        class="rounded-lg border border-neutral-200 bg-neutral-50 p-4 dark:border-neutral-700 dark:bg-neutral-900"
      >
        <ul class="flex flex-col items-center space-y-4">
          <NavMenuList />
          <li><ContactButton /></li>
        </ul>
      </div>
    </div>
  </div>
</nav>

<script>
  const menuButton = document.getElementById("nav-menu-mobile-button");
  const mobileMenu = document.getElementById("nav-menu-mobile");
  const closeIcon = document.getElementById("nav-button-close");
  const menuIcon = document.getElementById("nav-button-menu");
  const overlay = document.getElementById("nav-overlay");

  let isMenuOpen = false;

  function toggleMenu() {
    isMenuOpen = !isMenuOpen;

    if (mobileMenu) {
      if (isMenuOpen) {
        mobileMenu.classList.add("visible", "opacity-100", "translate-y-0");
        mobileMenu.classList.remove("invisible", "opacity-0", "-translate-y-2");
      } else {
        mobileMenu.classList.remove("visible", "opacity-100", "translate-y-0");
        mobileMenu.classList.add("invisible", "opacity-0", "-translate-y-2");
      }
    }

    if (overlay) {
      if (isMenuOpen) {
        overlay.classList.add("visible", "opacity-100");
        overlay.classList.remove("invisible", "opacity-0");
        document.body.style.overflow = "hidden";
      } else {
        overlay.classList.remove("visible", "opacity-100");
        overlay.classList.add("invisible", "opacity-0");
        document.body.style.overflow = "";
      }
    }

    if (closeIcon && menuIcon) {
      closeIcon.style.display = isMenuOpen ? "block" : "none";
      menuIcon.style.display = isMenuOpen ? "none" : "block";
    }
  }

  overlay?.addEventListener("click", () => {
    if (isMenuOpen) {
      toggleMenu();
    }
  });

  menuButton?.addEventListener("click", toggleMenu);
</script>
